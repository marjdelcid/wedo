# wedo. — variables de entorno
# Copia a .env.local (local) y configura las mismas en Vercel (producción).

# Supabase (cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (solo server — API routes; JAMÁS exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Diseñador IA de invitaciones
# Tema → diseño (paleta/tipografía/frase/prompt de imagen)
ANTHROPIC_API_KEY=
# Proveedor de imagen para la portada: openai (default) | fal | replicate
IMAGE_PROVIDER=openai
OPENAI_API_KEY=
# FAL_KEY=            # si IMAGE_PROVIDER=fal (stub, ver app/lib/ai/fal.ts)
# REPLICATE_API_TOKEN=  # si IMAGE_PROVIDER=replicate (stub, ver app/lib/ai/replicate.ts)
